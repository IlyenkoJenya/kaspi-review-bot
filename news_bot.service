[Unit]
Description=News Bot — Telegram news aggregator
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/news_bot
EnvironmentFile=/home/YOUR_USER/news_bot/.env
ExecStart=/home/YOUR_USER/news_bot/.venv/bin/python -m src.main
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
